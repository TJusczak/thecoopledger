{
  "name": "thecoopledger",
  "compatibility_date": "2026-07-10",
  "assets": {
    "directory": "./dist"
  },
  "env": {
    "beta": {
      "name": "thecoopledger-beta",
      "assets": {
        "directory": "./dist"
      },
      "routes": [
        { "pattern": "beta.thecoopledger.com/*", "custom_domain": true }
      ]
    }
  }
}
